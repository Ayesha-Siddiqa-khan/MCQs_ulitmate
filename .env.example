# =============================================================================
# MCQ Mentor — root example env file.
#
# Architecture:
#
#   Browser ──(NEXT_PUBLIC_*)──▶  Next.js frontend  ──(bearer JWT)──▶  FastAPI backend  ──▶  Supabase / AI / Storage
#
# Rules:
#   1. Anything starting with NEXT_PUBLIC_ is exposed to the browser. It is
#      safe to publish (Supabase URL, anon key, backend base URL). Server-only
#      secrets MUST NOT be prefixed with NEXT_PUBLIC_.
#   2. Server-only secrets live in backend/.env and are read by FastAPI's
#      pydantic-settings (see backend/app/core/config.py).
#   3. Do not put real secrets in any *.env* file that is committed. The
#      root .gitignore ignores every variant below.
# =============================================================================

# ---- Frontend (Next.js) -----------------------------------------------------
# Mirror these in frontend/.env.local.
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-or-publishable-key
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# ---- Backend (FastAPI) ------------------------------------------------------
# Mirror these in backend/.env. Full template: backend/.env.example.
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-anon-or-publishable-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-server-only
SUPABASE_JWT_SECRET=your-jwt-secret-server-only
SUPABASE_STORAGE_BUCKET=materials

BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
ALLOWED_ORIGINS=http://localhost:3000

DATABASE_URL=
ENCRYPTION_KEY=

OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
