# =============================================================================
# MCQ Mentor — git ignore rules.
# Real env files (with secrets) MUST never be committed. Examples are kept
# (every *.env.example file is intentionally allowed).
# =============================================================================

# Env (all real variants, anywhere in the repo)
.env
.env.local
.env.*.local
.env.development
.env.production
.env.development.local
.env.production.local
**/backend/.env
**/frontend/.env
**/frontend/.env.local
**/.env
!**/.env.example
!**/backend/.env.example
!**/frontend/.env.example
# Belt and braces: ignore any file literally named "secrets" or
# "credentials" at any depth.
**/secrets
**/secrets.json
**/secrets.yaml
**/secrets.yml
**/credentials
**/credentials.json

# Node
node_modules/
.next/
out/
.turbo/
.vercel/
.swc/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
next-env.d.ts
*.tsbuildinfo

# Python
__pycache__/
*.py[cod]
*$py.class
.venv/
venv/
.env.bak
.eggs/
*.egg-info/
.pytest_cache/
.mypy_cache/
.ruff_cache/
dist/
build/

# uv
.python-version

# OS
.DS_Store
Thumbs.db
desktop.ini

# IDE
.vscode/
.idea/
*.swp

# Playwright
playwright-report/
test-results/
blob-report/
.playwright/

# Local uploads / tmp
tmp/
uploads/

# Logs
*.log
logs/

# Coverage
coverage/
.coverage
htmlcov/

.vercel
.env*
