# =============================================================================
# Backend environment — example only. Copy to backend/.env and fill in.
# NEVER commit a real .env. The real file is in .gitignore.
#
# All variables here are SERVER-ONLY. The browser never sees them.
# The frontend reads ONLY NEXT_PUBLIC_* variables, defined in
# frontend/.env.example.
# =============================================================================

# ---- App --------------------------------------------------------------------
APP_ENV=development
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
# Comma-separated list of origins allowed to call the API.
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ---- Supabase (server-side) -------------------------------------------------
# Find all three in Supabase Dashboard → Project Settings → API.
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-anon-or-publishable-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-NEVER-EXPOSE-TO-BROWSER
SUPABASE_JWT_SECRET=your-jwt-secret
SUPABASE_STORAGE_BUCKET=materials

# ---- Direct Postgres (optional) ---------------------------------------------
# Format: postgresql://postgres:[PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres
# Leave blank if you only talk to Supabase via the Data API.
DATABASE_URL=

# ---- Encryption -------------------------------------------------------------
# Optional Fernet key. If empty, derived from SUPABASE_JWT_SECRET.
# Generate:  python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=

# ---- AI provider fallbacks (server-side, optional) --------------------------
# These are FALLBACKS only. Students normally bring their own key in Settings.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
