# =============================================================================
# Frontend (Next.js) public env — TEMPLATE ONLY.
# Copy to frontend/.env.local and fill in.
#
# RULE: only NEXT_PUBLIC_* values belong in this file. They are exposed to
# the browser. Never put service-role keys, AI provider keys, JWT secrets,
# database passwords, or any other server-only secret here. Server-side
# secrets live in backend/.env on the FastAPI host.
# =============================================================================

NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-or-publishable-key

# Where the browser can reach the FastAPI backend.
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
