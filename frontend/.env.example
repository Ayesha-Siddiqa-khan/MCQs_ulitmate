# =============================================================================
# Frontend (Next.js) public env — TEMPLATE ONLY.
# Copy to frontend/.env.local and fill in.
#
# RULE: the frontend may only read NEXT_PUBLIC_* values. They are exposed
# to the browser. NEVER put a Supabase URL, anon key, service-role key,
# JWT secret, AI provider key, database password, or any other server-only
# secret here. Those belong in backend/.env on the FastAPI host.
#
# The frontend does NOT talk to Supabase directly. It only calls the
# FastAPI backend via the URL below. The backend owns the Supabase
# service-role key, JWT secret, AI provider fallbacks, etc.
# =============================================================================

NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
